# ── AntiGravity Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=AntiGravity API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── PostgreSQL (Section 10.3, Table 10) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/antigravity

# ── Redis (Section 10.3) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Secrets (Section 5.2) ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace-with-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS (Section 5.3) ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── SMTP Email (Section 10.3) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@antigravity.app

# ── Firebase Push Notifications (Section 10.3) ───────────────────────────────
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# ── Rate Limiting (Section 5.3) ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
